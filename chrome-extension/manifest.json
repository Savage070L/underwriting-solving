{
  "manifest_version": 3,
  "name": "Standard Life — мост к stat.gov.kz",
  "version": "0.5.0",
  "description": "Тянет данные по БИН со stat.gov.kz (ЭЦП-сессия), egov.kz (резидентство), statsnet.co и kyc.kz; держит сессии живыми в течение дня. Отдаёт андеррайтинговому приложению.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://stat.gov.kz/*",
    "https://egov.kz/*",
    "https://statsnet.co/*",
    "https://kyc.kz/*",
    "https://yandex.kz/*",
    "https://yandex.ru/*",
    "https://yandex.com/*",
    "https://duckduckgo.com/*",
    "https://savage070l.github.io/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://savage070l.github.io/*",
        "http://localhost:*/*",
        "http://127.0.0.1:*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Standard Life · stat.gov.kz bridge"
  }
}
